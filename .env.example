# 토스증권 OpenAPI 자격증명 (PC 웹에서 발급, tsck_live_... / tssk_live_...)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

# 계좌 식별자 (X-Tossinvest-Account 헤더). /api/v1/accounts 로 조회해서 채운다.
# 페이퍼 모드에서는 비워둬도 시세 조회는 동작한다.
TOSS_ACCOUNT_SEQ=

# 매매 모드: paper(가상주문) 또는 live(실주문). 기본 paper. live는 검증 게이트 통과 후에만.
TRADING_MODE=paper

# (옵션) Gemini API 키 — 뉴스/필터 보조용. 없으면 LLM 보조는 자동 비활성.
GEMINI_API_KEY=

# (옵션) 기본 베이스 URL 오버라이드
# TOSS_BASE_URL=https://openapi.tossinvest.com
